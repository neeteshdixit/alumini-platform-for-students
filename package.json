{
  "name": "alumini-platform-for-students",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start:backend": "npm --prefix backend run start",
    "build:frontend": "npm --prefix frontend run build",
    "db:init": "npm --prefix backend run prisma:push && npm --prefix backend run db:seed",
    "db:studio": "npm --prefix backend run prisma:studio"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.14"
  }
}
